pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            agent {
                docker {
                    image 'node:18-bullseye'
                    reuseNode true
                }
            }
            steps {
                sh 'node --version'
                sh 'npm --version'
                sh 'npm ci'
                sh 'npm run build'
            }
        }

        stage('Test (Jest)') {
            agent {
                docker {
                    image 'node:18-bullseye'
                }
            }
            steps {
                sh 'npm ci'
                sh 'npm test -- --watchAll=false --testResultsProcessor=jest-junit'
            }
        }

        stage('E2E (Playwright)') {
            when {
                expression { fileExists('playwright.config.js') }
            }
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.42.1-jammy'
                }
            }
            steps {
                sh 'npm ci'
                sh 'npx playwright install'
                sh 'npx playwright test'
            }
        }
    }

    post {
        always {
            junit 'reports/junit/*.xml'
            archiveArtifacts artifacts: 'build/**', fingerprint: true
        }
    }
}