pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            agent {
                docker {
                    image 'node:18-bullseye'   // ⚠️ NE alpine!
                    args '-u root:root'
                }
            }
            steps {
                sh '''
                    node --version
                    npm --version
                    npm ci
                    npm run build
                '''
            }
        }

        stage('Test (Jest)') {
            agent {
                docker {
                    image 'node:18-bullseye'
                    args '-u root:root'
                }
            }
            steps {
                sh '''
                    npm test -- --watchAll=false --testResultsProcessor=jest-junit
                '''
            }
        }

        stage('E2E (Playwright)') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.42.1-jammy' // ✅ ima sve browser-e
                    args '--ipc=host'
                }
            }
            steps {
                sh '''
                    npm ci
                    npx playwright test
                '''
            }
        }
    }

    post {
        always {
            junit '**/junit.xml'
            archiveArtifacts artifacts: 'test-results/**', allowEmptyArchive: true
        }
    }
}