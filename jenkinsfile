pipeline {
    agent any

    stages {
        stage('w/o docker') { 
            steps { 
                sh '''
                    echo 'Hello World'
                    echo 'bez kontejnera kreiranje file-a'
                    ls -la
                    touch container-no.txt
                '''
            } 
        }
        stage("w/ docker") {
            agent {
                docker {
                    image 'node:18-alpine'
                }
            }
            steps {
                sh '''
                    echo 'with docker'
                    echo 'npm --version'
                    touch container-yes.txt
                '''
            }
        }
    }
}
